# Scrapebadger — required for X/Twitter fetch
# https://scrapebadger.com/
SCRAPEBADGER_API_KEY=

# Classification mode (default: keyword-only, no API credits)
REG_MONITOR_USE_LLM=false

# Optional: auto-enrich summaries after each crawl via Claude Code CLI
# Requires `claude` CLI logged in (subscription). No API key needed.
REG_MONITOR_ENRICH_AFTER_CRAWL=false

# Anthropic — only needed if REG_MONITOR_USE_LLM=true
# ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
REG_MONITOR_MAX_ACCOUNTS_PER_RUN=15
REG_MONITOR_WINDOW_MODE=et_noon_rolling_24h
REG_MONITOR_SINCE_HOURS=24
REG_MONITOR_SITE_WINDOW_HOURS=24
REG_MONITOR_PAGES_PER_USER=1
SC_CALLER_ID=job:reg-monitor
